{
  "name": "nestjs-microservices-test-task",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start:producer": "npm --workspace @app/producer run start:dev",
    "start:consumer": "npm --workspace @app/consumer run start:dev",
    "start:telegram": "npm --workspace @app/telegram run start:dev",
    "dev": "node ./node_modules/turbo/bin/turbo run start:dev --parallel --no-daemon --output-logs full",
    "build:all": "node ./node_modules/turbo/bin/turbo run build --parallel",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "test": "npm run test:unit",
    "test:unit": "npx jest --config jest.config.ts --runInBand",
    "lint": "npm --workspace @app/producer run lint && npm --workspace @app/consumer run lint && npm --workspace @app/telegram run lint"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "ts-node": "^10.9.1",
    "npm-run-all": "^4.1.5",
    "turbo": "^1.12.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "@types/jest": "^29.5.4"
  }
}
